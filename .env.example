# Backend
SERVER_PORT=9000

# Supabase/Postgres (optional; leave unset to use local H2)
# SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/postgres
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=<password>
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# Legacy fallback names also supported
# SUPABASE_DB_URL=jdbc:postgresql://<host>:5432/postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=<password>

# Spotify + YouTube integrations
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_API_KEY=

# Reliability tuning
SPOTIFY_SAFE_FALLBACK_ENABLED=false
YOUTUBE_MATCH_THRESHOLD=0.45
YOUTUBE_RETRY_MATCH_THRESHOLD=0.40

# CORS (comma-separated)
# Example: CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-preview.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173
