# Local backend URL for development.
# In Vercel, set VITE_API_URL to your deployed backend domain.
VITE_API_URL=http://localhost:9000

# Spotify OAuth app client ID used by frontend PKCE login.
VITE_SPOTIFY_CLIENT_ID=cad9f9f5d0a849fe85088ec49c7156fa

# Must exactly match a Redirect URI configured in Spotify Developer Dashboard.
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173

# Google OAuth client ID for frontend login.
VITE_GOOGLE_CLIENT_ID=

# Must exactly match an authorized redirect URI in Google Cloud Console.
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/callback
